generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum SourceType {
  ARTICLE
  TWEET
  VIDEO
  UPLOAD
  MANUAL
}

// --- Tenant ---

model Tenant {
  id              String   @id @default(cuid())
  
  // Routing & Identity
  slug            String   @unique                // e.g., "english", "korea", "japan"
  domain          String   @unique @map("domain") // e.g., "korea.example.com"
  siteName        String   @map("site_name")      // The display name for the site
  
  // Localization
  defaultLanguage String   @default("en") @map("default_language") // e.g., "en", "ko", "ja"
  
  // Visual Branding (Add these for your Logo logic)
  logoUrl         String?  @map("logo_url")
  faviconUrl      String?  @map("favicon_url")
  
  // Status & Metadata
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  users            User[]
  categories       Category[]
  subscribers      Subscriber[]
  contentArticles  ContentArticle[]
  rawArticles      RawArticle[]
  rawTweets        RawTweet[]
  rawVideos        RawVideo[]
  rawSourceUploads RawSourceUpload[]
  crawledUrls      CrawledUrl[]
  crawlJobs        CrawlJob[]
  socialChannels   SocialChannel[]
  banners          Banner[]

  @@map("tenants")
}

// --- Core User & Subscription Models ---

model User {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  firstName       String           @map("first_name")
  lastName        String           @map("last_name")
  email           String
  password        String
  role            String           @default("user")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  contentArticles ContentArticle[]

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Category {
  id                    String                 @id @default(cuid())
  tenantId              String                 @map("tenant_id")
  categoryName          String                 @map("category_name")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  contentArticles       ContentArticle[]
  rawArticles           RawArticle[]
  subscriberPreferences SubscriberPreference[]

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, categoryName])
  @@index([tenantId])
  @@map("categories")
}

model Subscriber {
  id            String                 @id @default(cuid())
  tenantId      String                 @map("tenant_id")
  email         String
  isVerified    Boolean                @default(false) @map("is_verified")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  attempts      Int                    @default(0)
  expiresAt     DateTime?              @map("expires_at")
  otpCode       String?                @map("otp_code")
  lastOtpSentAt DateTime?              @map("last_otp_sent_at")
  preferences   SubscriberPreference[]

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("subscribers")
}

model SubscriberPreference {
  id           String     @id @default(cuid())
  subscriberId String     @map("subscriber_id")
  categoryId   String     @map("category_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  category     Category   @relation(fields: [categoryId], references: [id])
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id])

  @@unique([subscriberId, categoryId], name: "subscriber_category_unique")
  @@map("subscriber_preferences")
}

// --- The "Published" Layer ---

model ContentArticle {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  usersId    String @map("users_id")
  categoryId String @map("category_id")

  // Sources (Exclusive Foreign Keys)
  rawArticleId      String? @unique @map("raw_article_id")
  rawTweetId        String? @unique @map("raw_tweets_id")
  rawVideoId        String? @unique @map("raw_youtube_id")
  rawSourceUploadId String? @unique @map("raw_source_uploads_id")

  title       String
  slug        String?    @unique
  publishDate DateTime?  @map("publish_date")
  imageUrl    String?    @map("image_url")
  content     String     @db.Text
  youtubeUrl  String?    @map("youtube_url")
  sourceType  SourceType @default(ARTICLE) @map("source_type")
  status      String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
  user     User     @relation(fields: [usersId], references: [id])

  rawArticle      RawArticle?      @relation(fields: [rawArticleId], references: [id])
  rawTweet        RawTweet?        @relation(fields: [rawTweetId], references: [id])
  rawVideo        RawVideo?        @relation(fields: [rawVideoId], references: [id])
  rawSourceUpload RawSourceUpload? @relation(fields: [rawSourceUploadId], references: [id])

  transformations ContentTransformation[]

  @@index([tenantId])
  @@map("content_articles")
}

// --- Raw Data Sources ---

model RawArticle {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  crawledUrlId String    @map("crawled_url_id")
  categoryId   String    @map("category_id")
  crawlJobId   String?   @map("crawl_jobs_id")
  title        String
  author       String?
  publishDate  DateTime? @map("publish_date")
  imageUrl     String?   @map("image_url")
  content      String?   @db.Text
  status       String    @default("pending")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  category       Category        @relation(fields: [categoryId], references: [id])
  crawledUrl     CrawledUrl      @relation(fields: [crawledUrlId], references: [id])
  crawlJob       CrawlJob?       @relation(fields: [crawlJobId], references: [id])
  contentArticle ContentArticle?

  @@index([tenantId])
  @@map("raw_articles")
}

model RawTweet {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  tweetId        String   @unique @map("tweet_id")
  sourceName     String?  @map("source_name")
  profileUrl     String?  @map("profile_url")
  text           String   @db.Text
  tweetTimestamp String?  @map("tweet_timestamp")
  hasMedia       Boolean  @default(false) @map("has_media")
  mediaType      String?  @map("media_type")
  mediaUrls      String[] @default([]) @map("media_urls")
  thumbnailUrl   String?  @map("thumbnail_url")
  status         String   @default("pending")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  contentArticle ContentArticle?

  @@index([tenantId])
  @@map("raw_tweets")
}

model RawVideo {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  language           String?
  youtubeUrl         String   @map("youtube_url")
  transcribedContent String   @map("transcribed_content") @db.Text
  prompt             String?  @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  contentArticle ContentArticle?

  @@index([tenantId])
  @@map("raw_videos")
}

model RawSourceUpload {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  prompt        String?  @db.Text
  s3ImageUrl    String?  @map("s3_image_url")
  language      String?
  extractedText String?  @map("extracted_text") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  contentArticle ContentArticle?

  @@index([tenantId])
  @@map("raw_source_uploads")
}

// --- Crawling & Automation Support ---

model CrawlJob {
  id                 String       @id @default(uuid())
  tenantId           String       @map("tenant_id")
  status             String       @default("PENDING")
  urls               String[]     @default([]) @map("urls")
  maxArticlesRequest Int          @default(10) @map("max_articles_request")
  articlesSaved      Int?         @default(0) @map("articles_saved")
  createdAt          DateTime     @default(now()) @map("created_at")
  startedAt          DateTime?    @map("started_at")
  finishedAt         DateTime?    @map("finished_at")
  rawArticles        RawArticle[]

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("crawl_jobs")
}

model CrawledUrl {
  id          String       @id @default(cuid())
  tenantId    String       @map("tenant_id")
  url         String       
  status      String
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  rawArticles RawArticle[]

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, url])
  @@index([tenantId])
  @@map("crawled_urls")
}

// --- Social Media Distribution ---

model ContentTransformation {
  id                 String            @id @default(cuid())
  contentArticleId   String            @map("content_article_id")
  socialChannelsId   String            @map("social_channels_id")
  tone               String?
  formatType         String?           @map("format_type")
  transformedTitle   String?           @map("transformed_title")
  transformedContent String?           @map("transformed_content")
  status             String
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  contentArticle     ContentArticle    @relation(fields: [contentArticleId], references: [id])
  socialChannel      SocialChannel     @relation(fields: [socialChannelsId], references: [id])
  socialMediaPosts   SocialMediaPost[]

  @@map("content_transformations")
}

model SocialChannel {
  id              String                  @id @default(cuid())
  tenantId        String                  @map("tenant_id")
  socialMediaName String                  @map("social_media_name")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  transformations ContentTransformation[]

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("social_channels")
}

model SocialMediaPost {
  id                      String                @id @default(cuid())
  contentTransformationId String                @map("content_transformation_id")
  postUrl                 String?               @map("post_url")
  mediaUrl                Json?                 @map("media_url")
  postedAt                DateTime?             @map("posted_at")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  transformation          ContentTransformation @relation(fields: [contentTransformationId], references: [id])

  @@map("social_media_posts")
}

model Banner {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String   @map("name")
  imageUrl  String   @map("image_url")
  linkUrl   String   @map("link_url")
  altText   String?  @map("alt_text")
  positions String[] @map("positions")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("banners")
}