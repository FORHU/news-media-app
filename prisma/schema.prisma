generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  firstName       String           @map("first_name")
  lastName        String           @map("last_name")
  email           String           @unique
  password        String
  role            String           @default("user")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  contentArticles ContentArticle[]

  @@map("users")
}

model Category {
  id                    String                 @id @default(cuid())
  categoryName          String                 @map("category_name")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  contentArticles       ContentArticle[]
  rawArticles           RawArticle[]
  subscriberPreferences SubscriberPreference[]

  @@map("categories")
}

model ContentArticle {
  id              String                   @id @default(cuid())
  usersId         String                   @map("users_id")
  categoryId      String                   @map("category_id")
  rawArticleId    String?                  @unique @map("raw_article_id")
  title           String
  slug            String?                  @unique
  publishDate     DateTime?                @map("publish_date")
  imageUrl        String?                  @map("image_url")
  content         String
  youtubeUrl      String?                  @map("youtube_url")
  status          String
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  category        Category                 @relation(fields: [categoryId], references: [id])
  user            User                     @relation(fields: [usersId], references: [id])
  rawArticle      RawArticle?              @relation(fields: [rawArticleId], references: [id])
  transformations ContentTransformation[]

  @@map("content_articles")
}

model RawArticle {
  id           String    @id @default(cuid())
  crawledUrlId String    @map("crawled_url_id")
  categoryId   String    @map("category_id")
  crawlJobId   String?   @map("crawl_jobs_id")
  title        String
  author       String?
  publishDate  DateTime? @map("publish_date")
  imageUrl     String?   @map("image_url")
  content      String?   @map("content")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  status       String    @default("pending")
  category     Category  @relation(fields: [categoryId], references: [id])
  crawledUrl   CrawledUrl @relation(fields: [crawledUrlId], references: [id])
  crawlJob     CrawlJob?  @relation(fields: [crawlJobId], references: [id])
  contentArticle ContentArticle?

  @@map("raw_articles")
}

model CrawlJob {
  id                 String      @id @default(uuid())
  status             String      @default("PENDING")
  urls               String[]    @default([]) @map("urls")
  maxArticlesRequest Int         @default(10) @map("max_articles_request")
  articlesSaved      Int?        @default(0) @map("articles_saved")
  createdAt          DateTime    @default(now()) @map("created_at")
  startedAt          DateTime?   @map("started_at")
  finishedAt         DateTime?   @map("finished_at")
  rawArticles        RawArticle[]

  @@map("crawl_jobs")
}

model CrawledUrl {
  id          String        @id @default(cuid())
  url         String        @unique
  status      String
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  rawArticles RawArticle[]

  @@map("crawled_urls")
}

model ContentTransformation {
  id                   String             @id @default(cuid())
  contentArticleId     String             @map("content_article_id")
  socialChannelsId     String             @map("social_channels_id")
  tone                 String?
  formatType           String?            @map("format_type")
  transformedTitle     String?            @map("transformed_title")
  transformedContent   String?            @map("transformed_content")
  status               String
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  contentArticle       ContentArticle     @relation(fields: [contentArticleId], references: [id])
  socialChannel        SocialChannel      @relation(fields: [socialChannelsId], references: [id])
  socialMediaPosts     SocialMediaPost[]

  @@map("content_transformations")
}

model SocialChannel {
  id              String                   @id @default(cuid())
  socialMediaName String                   @map("social_media_name")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  transformations ContentTransformation[]

  @@map("social_channels")
}

model SocialMediaPost {
  id                      String                @id @default(cuid())
  contentTransformationId String                @map("content_transformation_id")
  postUrl                 String?               @map("post_url")
  mediaUrl                Json?                 @map("media_url")
  postedAt                DateTime?             @map("posted_at")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  transformation          ContentTransformation @relation(fields: [contentTransformationId], references: [id])

  @@map("social_media_posts")
}

model Subscriber {
  id            String                 @id @default(cuid())
  email         String                 @unique
  isVerified    Boolean                @default(false) @map("is_verified")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  attempts      Int                    @default(0)
  expiresAt     DateTime?              @map("expires_at")
  otpCode       String?                 @map("otp_code")
  lastOtpSentAt DateTime?              @map("last_otp_sent_at")
  preferences   SubscriberPreference[]

  @@map("subscribers")
}

model SubscriberPreference {
  id           String     @id @default(cuid())
  subscriberId String     @map("subscriber_id")
  categoryId   String     @map("category_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  category     Category   @relation(fields: [categoryId], references: [id])
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id])

  @@unique([subscriberId, categoryId], name: "subscriber_category_unique")
  @@map("subscriber_preferences")
}
